/**
 * ODBC extension definitions.
 *
 * Cross-platform D translation of the ODBC 4.0 `sqlext.h` header (the
 * Microsoft SQL extensions to the ODBC Core API). These bindings always
 * expose the full ODBC 4.0 (`ODBCVER == 0x0400`) surface.
 *
 * Windows-only / Microsoft-only facilities (the Visual Studio Analyzer
 * `Trace*` / `FireVSDebugEvent` entry points, the `ODBC_VS_ARGS` structure and
 * the connection-pooling `ODBCSetTryWaitValue` / `ODBCGetTryWaitValue`
 * helpers) are intentionally omitted.
 *
 * License: $(LINK2 http://www.boost.org/LICENSE_1_0.txt, Boost License 1.0)
 */
module etc.c.odbc.sqlext;

public import etc.c.odbc.sql;

